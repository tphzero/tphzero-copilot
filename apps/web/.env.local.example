# LLM: Google Gemini en la nube (por defecto) o modelos locales vía Ollama (ai-sdk-ollama: mejor soporte de tools).
# Para Ollama: AI_PROVIDER=ollama y deja GOOGLE_GENERATIVE_AI_API_KEY vacío (no se usa).
# Para Gemini API: quita AI_PROVIDER o déjalo en blanco y pon tu clave de Google AI Studio.
GOOGLE_GENERATIVE_AI_API_KEY=
AI_PROVIDER=
# Por defecto qwen2.5:7b (suele ir bien con function calling). Alternativas: gemma4:e4b, llama3.2, qwen2.5:14b
OLLAMA_MODEL=qwen2.5:7b
# Base del API de Ollama (sin /api). Por defecto http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Supabase (cloud o local)
# Cloud: Project Settings → API → `npm run dev` (sin comentar las tres lineas siguientes).
# Local con `npm run dev:local` / `dev:local:fresh`: comenta las 3 lineas de Supabase en este archivo y en apps/web/.env si aplica (el script no escribe .env; ver docs/LOCAL-DATABASE.md seccion «Antes de dev:local»).
# Local manual: `npm run db:status` y pegar aqui si usas `npm run dev` sin dev:local*
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
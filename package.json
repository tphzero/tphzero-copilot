{
  "name": "tphzero-copilot",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:local:fresh": "node scripts/dev-local.mjs --fresh",
    "stop:local": "node scripts/stop-local.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status"
  },
  "devDependencies": {
    "supabase": "^2.88.1",
    "turbo": "^2.9.5"
  }
}
